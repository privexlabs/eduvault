# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/eduvault
MONGODB_DB=eduvault

# Database Tuning Limits
MONGODB_MAX_POOL_SIZE=150
MONGODB_MIN_POOL_SIZE=20
MONGODB_TIMEOUT_MS=5000

# Auth
JWT_SECRET=replace-with-a-long-random-string
# Comma-separated wallet addresses granted admin access (case-insensitive).
# Users with role="admin" in MongoDB are also granted access automatically.
ADMIN_WALLETS=

# Uploads
PINATA_JWT=
NEXT_PUBLIC_GATEWAY_URL=

# Email
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# WalletConnect / Reown (optional)
# Leave blank (or omit) in local/preview builds.
# When unset, WalletConnect is disabled at build time and no remote config
# fetch is made — only the injected and Coinbase connectors remain active.
# Obtain a real project ID at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Stellar / Soroban Configuration
# All chain-specific settings are consumed via src/lib/config/chain.js as a
# single source of truth. Change values here to affect the entire application.
NEXT_PUBLIC_STELLAR_NETWORK=testnet
# Soroban RPC endpoint (defaults to https://soroban-testnet.stellar.org)
NEXT_PUBLIC_STELLAR_RPC_URL=
# Horizon URL (defaults based on STELLAR_NETWORK)
NEXT_PUBLIC_HORIZON_URL=
# Stellar expert explorer URL (defaults based on STELLAR_NETWORK)
NEXT_PUBLIC_EXPLORER_URL=
# Soroban contract IDs — set these after deployment
NEXT_PUBLIC_MATERIAL_REGISTRY_CONTRACT_ID=
NEXT_PUBLIC_PURCHASE_MANAGER_CONTRACT_ID=
NEXT_PUBLIC_SOROBAN_CONTRACT_ID=
# Default accepted asset for payments
NEXT_PUBLIC_ACCEPTED_ASSET=USDC
# EVM upload contract address (Celo Sepolia by default)
NEXT_PUBLIC_UPLOAD_CONTRACT_ADDRESS=0x3f48520ca0d8d51345b416b5a3e083dac8790f55

# Stellar admin keypair (used by recovery and refund services — server-side only)
STELLAR_ADMIN_PUBLIC_KEY=
STELLAR_ADMIN_SECRET=

# Horizon failover configuration (issue #383)
# Space or comma-separated list of backup Horizon endpoints tried in order
# when the primary node is unavailable.
STELLAR_HORIZON_FALLBACKS=
STELLAR_HORIZON_TIMEOUT_MS=8000
STELLAR_HORIZON_RETRIES=2

# Surge pricing / base fee detection (issue #385)
# p95 fee threshold in stroops above which surge pricing is triggered (default 500)
STELLAR_SURGE_FEE_THRESHOLD=500
# Fee multiplier applied during surge (default 3x)
STELLAR_SURGE_FEE_MULTIPLIER=3
# Higher multiplier for extreme congestion (default 5x)
STELLAR_HIGH_SURGE_FEE_MULTIPLIER=5
# Hard ceiling for the transaction fee we are willing to pay in stroops (default 10000)
STELLAR_MAX_FEE_STROOPS=10000

# Transaction recovery indexer (issue #384)
# Number of recent ledgers to scan when running recovery mode
RECOVERY_LOOKBACK_LEDGERS=200

# Checkout wallet address verification (issue #386)
# Number of repeated address mismatches before the session is cleared
CHECKOUT_MAX_ADDRESS_WARNINGS=2

# Deployment notes
# - Replace placeholder values before production deployment.
# - JWT_SECRET, MONGODB_URI, PINATA_JWT, and NEXT_PUBLIC_APP_URL are required for production.
# - Stellar RPC, Horizon, and contract IDs are required once Soroban features are enabled.
# - See src/lib/config/chain.js for default fallback values.
